---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	tags?: string[];
	sectionLabel?: string;
	coverImage?: string;
	coverAlt?: string;
}

const { title, description, pubDate, updatedDate, tags = [], sectionLabel, coverImage, coverAlt } = Astro.props;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} image={coverImage} />
	</head>
	<body>
		<Header />
		<main>
			<article class="entry">
				<div class="entry-header">
					{coverImage && (
						<div class="cover-wrap">
							<img class="cover-image" src={coverImage} alt={coverAlt ?? title} />
						</div>
					)}
					{sectionLabel && <p class="eyebrow">{sectionLabel}</p>}
					<h1>{title}</h1>
					<p class="description">{description}</p>
					<div class="meta">
						<span><FormattedDate date={pubDate} /></span>
						{updatedDate && <span>업데이트 <FormattedDate date={updatedDate} /></span>}
					</div>
					{
						tags.length > 0 && (
							<ul class="tags">
								{tags.map((tag) => <li>{tag}</li>)}
							</ul>
						)
					}
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.entry {
		display: grid;
		gap: 2rem;
	}

	.entry-header {
		padding: 2rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.88);
		box-shadow: 0 18px 50px rgba(var(--gray), 0.12);
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		font-size: 0.9rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
	}

	h1 {
		margin-bottom: 0.75rem;
	}

	.cover-wrap {
		margin: -0.5rem -0.5rem 1.5rem;
	}

	.cover-image {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: 20px;
		border: 1px solid rgb(var(--gray-light));
	}

	.description {
		margin: 0;
		font-size: 1.05rem;
		color: rgb(var(--gray));
	}

	.meta {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 1rem;
		font-size: 0.95rem;
		color: rgb(var(--gray));
	}

	.tags {
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
		display: flex;
		gap: 0.6rem;
		flex-wrap: wrap;
	}

	.tags li {
		padding: 0.35rem 0.75rem;
		border-radius: 999px;
		background: rgb(var(--gray-light));
		font-size: 0.9rem;
	}

	.prose {
		padding: 0 0.25rem;
	}
</style>
