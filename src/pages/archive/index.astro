---
import { getCollection } from 'astro:content';
import FormattedDateShort from '../../components/FormattedDateShort.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { withBase } from '../../utils/withBase';

const entries = (await getCollection('archive', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<PageLayout title="아카이브 | 까베밍 월드" description="생활과 에피소드 기록을 쌓아두는 메인 아카이브">
	<section class="section-intro">
		<p class="eyebrow">ARCHIVE</p>
		<h1>생활 기록 아카이브</h1>
		<p>까베밍 월드의 일상, 에피소드, 기념일, 감정선이 시간순으로 쌓이는 메인 기록 공간.</p>
	</section>

	<section class="stack-list">
		{entries.map((entry) => (
			<a class="card list-card" href={withBase(`archive/${entry.id}/`)}>
				<div>
					<p class="entry-type">{entry.data.category ?? '기록'}</p>
					<h2>{entry.data.title}</h2>
					<p>{entry.data.description}</p>
				</div>
				<span class="date"><FormattedDateShort date={entry.data.pubDate} /></span>
			</a>
		))}
	</section>
</PageLayout>
