---
import { getCollection } from 'astro:content';
import FormattedDateShort from '../components/FormattedDateShort.astro';
import PageLayout from '../layouts/PageLayout.astro';
import { withBase } from '../utils/withBase';

const [archiveEntries, worldEntries, noteEntries] = await Promise.all([
	getCollection('archive', ({ data }) => !data.draft),
	getCollection('world', ({ data }) => !data.draft),
	getCollection('notes', ({ data }) => !data.draft),
]);

const latestArchive = archiveEntries.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 2);
const latestWorld = worldEntries.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 2);
const latestNotes = noteEntries.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 2);
---

<PageLayout title="까베밍 월드" description="기록과 설정과 프로젝트 노트를 차곡차곡 쌓는 아카이브형 홈 화면">
	<section class="hero card hero-card">
		<div>
			<p class="eyebrow">까베밍 월드 아카이브</p>
			<h1>까맹과 베르와 밍밍의 생활, 설정, 작업 기록을 다정하게 쌓아두는 곳.</h1>
			<p class="lead">
				오늘의 생활 장면, 오래 남길 세계관 메모, 같이 굴러가는 프로젝트 노트까지.
				흩어지지 않게 모아두고, 나중에 다시 꺼내 읽을 수 있게 정리한다.
			</p>
			<p class="hero-note">
				사소한 하루도 기록이 되고, 기록은 결국 까베밍 월드의 분위기가 된다.
			</p>
			<div class="brand-card card">
				<p class="brand-card-kicker">까베밍 월드 노트</p>
				<h2>생활감, 관계성, 팀의 흐름이 모이는 아카이브.</h2>
				<p>까베밍 월드는 셋의 하루와 세계관을 함께 기록하는 팀 블로그다.</p>
			</div>
		</div>
		<div class="hero-visual card">
			<div class="visual-badge">까베밍 월드</div>
			<div class="hero-banner-placeholder" role="img" aria-label="추후 실제 홈 배너 이미지가 들어올 자리">
				<div class="placeholder-badge">배너 자리</div>
				<p>이따 짤라줄 실제 배너가 들어오면 바로 교체할 수 있게 미리 자리만 잡아둠.</p>
			</div>
			<div class="visual-core">
				<span>까맹</span>
				<span>베르</span>
				<span>밍밍</span>
			</div>
			<p class="visual-copy">생활감, 관계성, 팀의 흐름을 한 자리에 모으는 기록 저장소.</p>
		</div>
		<div class="hero-meta">
			<div>
				<strong>{archiveEntries.length}</strong>
				<span>생활 기록</span>
			</div>
			<div>
				<strong>{worldEntries.length}</strong>
				<span>월드 설정</span>
			</div>
			<div>
				<strong>{noteEntries.length}</strong>
				<span>프로젝트 노트</span>
			</div>
		</div>
	</section>

	<section class="grid two-up section-gap">
		<a class="card feature-card" href={withBase('archive')}>
			<p class="eyebrow">생활 아카이브</p>
			<h2>아카이브</h2>
			<p>일상과 에피소드를 시간순으로 쌓는 메인 기록 저장소.</p>
		</a>
		<a class="card feature-card" href={withBase('world')}>
			<p class="eyebrow">월드 설정</p>
			<h2>월드 설정집</h2>
			<p>캐릭터와 관계의 기준을 모아두는 설정 묶음.</p>
		</a>
		<a class="card feature-card" href={withBase('notes')}>
			<p class="eyebrow">작업 노트</p>
			<h2>프로젝트 노트</h2>
			<p>운영과 기획, 세팅 과정을 남기는 작업 메모.</p>
		</a>
		<div class="card feature-card soft-card">
			<p class="eyebrow">기록의 결</p>
			<h2>기록 아카이브형 구조</h2>
			<p>다시 꺼내 이어볼 수 있는 기록을 우선한다.</p>
		</div>
	</section>

	<section class="section-gap">
		<div class="section-header">
			<div>
				<p class="eyebrow">최신 기록</p>
				<h2>첫 화면에서 바로 보이는 최신 기록</h2>
				<p class="section-copy">
					섹션별로 최신 두 편씩 묶어 그리드가 한 줄에서 균형 있게 보이도록 했다. 전체 목록은 각 아카이브·월드·노트 페이지에서 이어진다.
				</p>
			</div>
		</div>
		<div class="latest-feed">
			<div class="latest-block">
				<p class="eyebrow latest-block-kicker">아카이브</p>
				<div class="grid two-up">
					{latestArchive.map((entry) => (
						<a class="card entry-card" href={withBase(`archive/${entry.id}/`)}>
							{entry.data.coverImage && <img class="entry-card-image" src={entry.data.coverImage} alt={entry.data.coverAlt ?? entry.data.title} />}
							<div class="entry-card-body">
								<div class="entry-card-top">
									<p class="entry-type">아카이브</p>
									<p class="entry-date"><FormattedDateShort date={entry.data.pubDate} /></p>
								</div>
								<h3>{entry.data.title}</h3>
								<p>{entry.data.description}</p>
								<span class="entry-link">기록 읽기</span>
							</div>
						</a>
					))}
				</div>
			</div>
			<div class="latest-block">
				<p class="eyebrow latest-block-kicker">월드 설정집</p>
				<div class="grid two-up">
					{latestWorld.map((entry) => (
						<a class="card entry-card" href={withBase(`world/${entry.id}/`)}>
							{entry.data.coverImage && <img class="entry-card-image" src={entry.data.coverImage} alt={entry.data.coverAlt ?? entry.data.title} />}
							<div class="entry-card-body">
								<div class="entry-card-top">
									<p class="entry-type">월드 설정집</p>
									<p class="entry-date"><FormattedDateShort date={entry.data.pubDate} /></p>
								</div>
								<h3>{entry.data.title}</h3>
								<p>{entry.data.description}</p>
								<span class="entry-link">설정 보기</span>
							</div>
						</a>
					))}
				</div>
			</div>
			<div class="latest-block">
				<p class="eyebrow latest-block-kicker">프로젝트 노트</p>
				<div class="grid two-up">
					{latestNotes.map((entry) => (
						<a class="card entry-card" href={withBase(`notes/${entry.id}/`)}>
							{entry.data.coverImage && <img class="entry-card-image" src={entry.data.coverImage} alt={entry.data.coverAlt ?? entry.data.title} />}
							<div class="entry-card-body">
								<div class="entry-card-top">
									<p class="entry-type">프로젝트 노트</p>
									<p class="entry-date"><FormattedDateShort date={entry.data.pubDate} /></p>
								</div>
								<h3>{entry.data.title}</h3>
								<p>{entry.data.description}</p>
								<span class="entry-link">노트 보기</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</div>
	</section>
</PageLayout>

<style>
	.latest-feed {
		display: grid;
		gap: 2.25rem;
	}

	.latest-block-kicker {
		margin-bottom: 0.85rem;
	}

	.entry-card {
		overflow: hidden;
		padding: 0;
	}

	.entry-card-image {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-bottom: 1px solid rgb(var(--gray-light));
	}

	.entry-card-body {
		padding: 1.25rem;
	}
</style>
